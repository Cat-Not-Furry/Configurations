#!/bin/bash

# Obtener frecuencia
freq_ghz=$(awk '{printf "%.1f", $1/1000000}' /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq)
freq_num=$(echo "$freq_ghz" | sed 's/[^0-9.]//g')

# Rangos realistas con tus colores
if (($(echo "$freq_num >= 3.5" | bc -l 2>/dev/null))); then
  color="\033[1;31m" # Rojo (≥ 3.5 GHz) = tu ≥ 60
elif (($(echo "$freq_num >= 2.5" | bc -l 2>/dev/null))); then
  # Naranja/Rosa (2.5-3.49 GHz) = tu 50-59
  if tput colors | grep -q 256; then
    color="\033[38;5;208m"
  else
    color="\033[1;35m"
  fi
  icon="⚡"
elif (($(echo "$freq_num >= 1.5" | bc -l 2>/dev/null))); then
  color="\033[1;33m" # Amarillo (1.5-2.49 GHz) = tu 35-49
elif (($(echo "$freq_num >= 0.8" | bc -l 2>/dev/null))); then
  color="\033[1;34m" # Azul (0.8-1.49 GHz) = tu 20-34
else
  color="\033[1;32m" # Verde (< 0.8 GHz) = tu < 20
fi

NC='\033[0m'
echo -e "${color} ${freq_ghz}GHz${NC}"
