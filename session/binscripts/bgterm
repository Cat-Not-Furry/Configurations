#!/usr/bin/env bash

# bgterm - Ejecuta un programa en el fondo de pantalla.
# Soporta Wayland (terminal-bg) y X11/i3 (i3bgwin+urxvt).
# Si no hay servidor gráfico, espera automáticamente hasta que aparezca.
# Opción --transparent (-t) para fondo transparente (requiere compositor).

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

show_help() {
  cat <<EOF
Uso: bgterm [OPCIÓN] COMANDO [ARGUMENTOS...]

Ejecuta un programa de terminal (cava, btop, cmatrix...) como fondo de pantalla.
Detecta automáticamente Wayland o X11 (i3). Si no hay servidor gráfico activo,
espera hasta que aparezca (máximo 30 segundos).

Opciones:
  -h, --help        Muestra esta ayuda
  -w, --wait        Espera explícitamente (por defecto ya espera automáticamente)
  -n, --nowait      No espera; falla si no hay display activo
  -d, --display     Fuerza tipo: wayland|x11
  -t, --transparent Usa fondo transparente en la terminal (requiere compositor)

Ejemplos:
  bgterm cava                     # espera si es necesario
  bgterm -t btop                  # fondo transparente
  bgterm cmatrix -u 2
  bgterm --nowait cava            # falla si no hay display

Uso típico desde .xinitrc o script de WM:
  bgterm -t cava &
  exec i3
EOF
}

# Esperar a que haya un display (X11 o Wayland)
wait_for_display() {
  local timeout=30
  local elapsed=0
  echo -e "${YELLOW}Esperando servidor gráfico...${NC}"
  while [ $elapsed -lt $timeout ]; do
    if [ -n "$WAYLAND_DISPLAY" ] && [ -e "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]; then
      echo -e "${GREEN}✓ Wayland detectado${NC}"
      return 0
    fi
    if [ -n "$DISPLAY" ] && command -v xdpyinfo >/dev/null 2>&1 && xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
      echo -e "${GREEN}✓ X11 detectado (DISPLAY=$DISPLAY)${NC}"
      return 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done
  echo -e "${RED}✗ Tiempo de espera agotado. No se detectó servidor gráfico.${NC}"
  return 1
}

# Detectar servidor gráfico actual
detect_display() {
  if [ -n "$WAYLAND_DISPLAY" ] && [ -e "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]; then
    echo "wayland"
  elif [ -n "$DISPLAY" ] && command -v xdpyinfo >/dev/null 2>&1 && xdpyinfo -display "$DISPLAY" >/dev/null 2>&1; then
    echo "x11"
  else
    echo "none"
  fi
}

# Verificar ejecutable
check_cmd() {
  if ! command -v "$1" &>/dev/null; then
    echo -e "${RED}Error: No se encontró '$1'. Instálalo primero.${NC}"
    return 1
  fi
  return 0
}

# Modo Wayland (opcional --transparent)
run_wayland() {
  local cmd="$1"
  shift
  local args="$@"
  check_cmd "terminal-bg" || exit 1
  local transparent_flag=""
  if [ "$TRANSPARENT" = "yes" ]; then
    # Intentar usar --transparent si terminal-bg lo soporta
    if terminal-bg --help 2>&1 | grep -q -- "--transparent"; then
      transparent_flag="--transparent"
    else
      echo -e "${YELLOW}Advertencia: terminal-bg no soporta --transparent. Ignorando.${NC}"
    fi
  fi
  echo -e "${GREEN}▶ Wayland:${NC} terminal-bg $transparent_flag --script $cmd $args"
  exec terminal-bg $transparent_flag --script "$cmd" $args
}

# Modo X11 (i3bgwin + urxvt, con opción -tr si transparente)
run_x11() {
  local cmd="$1"
  shift
  local args="$@"
  check_cmd "i3bgwin" || exit 1
  check_cmd "urxvt" || exit 1
  if ! pgrep -x "picom" >/dev/null; then
    echo -e "${YELLOW}Advertencia: picom no está corriendo. La transparencia puede fallar.${NC}"
  fi
  local transparency_opts=""
  if [ "$TRANSPARENT" = "yes" ]; then
    transparency_opts="-tr -sh 85" # true transparency + shading 85%
  fi
  local urxvt_cmd="urxvt $transparency_opts -embed {windowid} -e $cmd $args"
  echo -e "${GREEN}▶ X11 (i3):${NC} i3bgwin $urxvt_cmd"
  exec i3bgwin $urxvt_cmd
}

# --- MAIN ---
WAIT_MODE="auto"
FORCED_DISPLAY=""
TRANSPARENT="no"

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h | --help)
    show_help
    exit 0
    ;;
  -w | --wait)
    WAIT_MODE="wait"
    shift
    ;;
  -n | --nowait)
    WAIT_MODE="nowait"
    shift
    ;;
  -d | --display)
    FORCED_DISPLAY="$2"
    shift 2
    ;;
  -t | --transparent)
    TRANSPARENT="yes"
    shift
    ;;
  *)
    break
    ;;
  esac
done

if [ $# -eq 0 ]; then
  echo -e "${RED}Error: Debes especificar un comando (cava, btop, cmatrix...).${NC}"
  echo "Usa 'bgterm --help' para más información."
  exit 1
fi

# Si se fuerza un tipo de display, lo usamos
if [ -n "$FORCED_DISPLAY" ]; then
  DISPLAY_TYPE="$FORCED_DISPLAY"
else
  DISPLAY_TYPE=$(detect_display)
fi

# Decidir si esperar o no
if [ "$DISPLAY_TYPE" = "none" ]; then
  if [ "$WAIT_MODE" = "nowait" ]; then
    echo -e "${RED}Error: No hay servidor gráfico y se usó --nowait.${NC}"
    exit 1
  else
    wait_for_display || exit 1
    DISPLAY_TYPE=$(detect_display)
    if [ "$DISPLAY_TYPE" = "none" ]; then
      echo -e "${RED}Error: Sigo sin detectar servidor gráfico.${NC}"
      exit 1
    fi
  fi
fi

# Ejecutar según el tipo
case "$DISPLAY_TYPE" in
wayland)
  run_wayland "$@"
  ;;
x11)
  run_x11 "$@"
  ;;
*)
  echo -e "${RED}Error: Tipo de display no soportado: $DISPLAY_TYPE${NC}"
  exit 1
  ;;
esac
