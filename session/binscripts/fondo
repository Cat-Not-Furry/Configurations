#!/usr/bin/env bash

DIR="${DIR:-$HOME/.config/i3/fondos}"
OTHER_DIR="$HOME/.config/i3/fondos/other"

if [[ $# -eq 0 ]]; then
  echo "Uso: fondo [f|s|t|a|k|h|sh]"
  echo "  f           - Fondo aleatorio (excluye 'other/')"
  echo "  s [número]  - Seleccionar fondo"
  echo "  p           - Fondo aleatorio pero es H (solo 'other/')"
  echo "  sp [número] - Seleccionar fondo del directorio H"
  echo "  t           - Iniciar/reiniciar picom"
  echo "  a           - Fondo aleatorio + picom"
  echo "  k           - Terminar picom"
  exit 0
fi

# Función para obtener imágenes excluyendo 'other'
get_main_images() {
  # Buscar en DIR pero excluir la subcarpeta other
  find "$DIR" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) 2>/dev/null
}

# Función para contar imágenes principales (sin 'other')
count_main_images() {
  get_main_images | wc -l
}

show_list() {
  local dir="$1"
  local title="$2"

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  files=()
  while IFS= read -r -d $'\0' file; do
    files+=("$(basename "$file")")
  done < <(find "$dir" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) -print0 2>/dev/null | sort -z)

  for i in "${!files[@]}"; do
    printf "  %2d. %-25s" "$((i + 1))" "${files[$i]}"
    if [[ $(((i + 1) % 2)) -eq 0 ]] || [[ $((i + 1)) -eq ${#files[@]} ]]; then
      echo ""
    fi
  done

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

select_fondo() {
  local dir="$1"
  local num="$2"

  if [[ ! -d "$dir" ]]; then
    echo "Directorio no encontrado: $dir"
    return 1
  fi

  if [[ -z "$(find "$dir" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) 2>/dev/null)" ]]; then
    echo "No hay imágenes en: $dir"
    return 1
  fi

  if [[ -n "$num" ]] && [[ "$num" =~ ^[0-9]+$ ]]; then
    img=$(find "$dir" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) 2>/dev/null | sort | sed -n "${num}p")
    if [[ -n "$img" ]]; then
      feh --bg-fill "$img"
      echo "Fondo establecido: $(basename "$img") (ID: $num)"
    else
      echo "No se encontró fondo con ID $num"
    fi
    return 0
  fi

  show_list "$dir" "Fondos disponibles en $(basename "$dir")"

  read -rp "Ingresa el número del fondo (o Enter para cancelar): " num

  if [[ -n "$num" ]] && [[ "$num" =~ ^[0-9]+$ ]]; then
    select_fondo "$dir" "$num"
  elif [[ -n "$num" ]]; then
    echo "'$num' no es un número válido"
  else
    echo "Selección cancelada"
  fi
}

case "$1" in
f)
  # Solo imágenes principales, excluyendo 'other/'
  count=$(count_main_images)

  if [[ $count -eq 0 ]]; then
    echo "No hay imágenes en $DIR (excluyendo 'other/')"
    echo "Formatos soportados: .jpg, .png, .jpeg"
    exit 1
  fi

  # Usar las imágenes principales (excluyendo 'other/')
  feh --randomize --bg-fill $(get_main_images | shuf -n 1)
  echo "Fondo aleatorio establecido (de $(basename "$DIR"), excluyendo 'other/')"
  echo "Imágenes disponibles en directorio principal: $count"
  ;;

s)
  select_fondo "$DIR" "${2:-}"
  ;;

p)
  if [[ ! -d "$OTHER_DIR" ]] || [[ -z "$(find "$OTHER_DIR" -maxdepth 1 -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) 2>/dev/null)" ]]; then
    echo "No hay imágenes en $OTHER_DIR"
    exit 1
  fi
  feh --randomize --bg-fill "$OTHER_DIR"/*
  echo "Fondo aleatorio establecido (solo 'other/')"
  ;;

sp)
  select_fondo "$OTHER_DIR" "${2:-}"
  ;;

t)
  killall picom 2>/dev/null
  picom --daemon --backend glx &
  echo "Picom"
  ;;

a)
  # Para la opción 'a' también usar solo imágenes principales
  count=$(count_main_images)

  if [[ $count -eq 0 ]]; then
    echo "No hay imágenes en $DIR (excluyendo 'other/')"
    exit 1
  fi

  # Usar imágenes principales para 'a' también
  feh --randomize --bg-fill $(get_main_images | shuf -n 1)
  killall picom 2>/dev/null
  picom --daemon --backend glx &
  echo "Fondo aleatorio + Picom (excluyendo 'other/')"
  ;;

k)
  killall picom 2>/dev/null && echo "Picom terminado" || echo "ℹ️  No corriendo"
  ;;

*)
  echo "Opción '$1' no válida"
  exit 1
  ;;
esac
