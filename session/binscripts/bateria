#!/usr/bin/env bash

set -euo pipefail

BAT_PATH="/sys/class/power_supply/BAT0"
if [[ ! -d "$BAT_PATH" ]]; then
    echo "No se detectó batería"
    exit 1
fi

capacity=$(cat "$BAT_PATH/capacity" 2>/dev/null || echo "0")
status=$(cat "$BAT_PATH/status" 2>/dev/null || echo "Desconocido")

if [[ $capacity -le 15 ]]; then
    color="\033[1;31m"
elif [[ $capacity -le 30 ]]; then
    color="\033[1;33m"
else
    color="\033[1;32m"
fi

echo -e "${color}${capacity}% - Estado: $status"
