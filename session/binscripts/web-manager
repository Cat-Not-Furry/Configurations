#!/bin/bash
# web-manager.sh - Gestión de servicios web (Apache y MariaDB)
# Autor: Arch Linux User
# Uso: web-manager.sh [comando]

# ============================================
# CONFIGURACIÓN
# ============================================
CONFIG_DIR="$HOME/.config/web-manager"
LOG_DIR="$CONFIG_DIR/logs"
BACKUP_DIR="$HOME/Backups/MySQL"
SERVICES=("httpd" "mariadb")
SERVICE_NAMES=("Apache" "MariaDB")
MYSQL_USER="root"
MYSQL_PASS="root" # Cambiar en producción

# ============================================
# COLORES Y FORMATOS
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ============================================
# FUNCIONES DE UTILIDAD
# ============================================
log() {
  echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

success() {
  echo -e "${GREEN}✓${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

warning() {
  echo -e "${YELLOW}⚠${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

error() {
  echo -e "${RED}✗${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

header() {
  echo -e "${CYAN}${BOLD}============================================${NC}"
  echo -e "${CYAN}${BOLD}    $1${NC}"
  echo -e "${CYAN}${BOLD}============================================${NC}"
}

check_root() {
  if [[ $EUID -eq 0 ]]; then
    error "No ejecutes este script como root/sudo. Usa tu usuario normal."
    exit 1
  fi
}

check_service() {
  systemctl is-active --quiet "$1" 2>/dev/null
}

check_mysql() {
  mariadb -u "$MYSQL_USER" -p"$MYSQL_PASS" -e "SELECT 1" &>/dev/null
}

# ============================================
# FUNCIONES PRINCIPALES
# ============================================

initialize() {
  header "INICIALIZACIÓN"
  mkdir -p "$CONFIG_DIR" "$LOG_DIR" "$BACKUP_DIR"
  success "Directorios creados en $CONFIG_DIR"
  for s in "${SERVICES[@]}"; do
    if ! systemctl list-unit-files | grep -q "$s.service"; then
      warning "$s no está instalado"
      read -p "¿Instalar $s ahora? (s/n): " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Ss]$ ]]; then
        sudo pacman -S --needed --noconfirm "$s"
        if [[ "$s" == "mariadb" ]]; then
          sudo mariadb-install-db --user=mysql --basedir=/usr --datadir=/var/lib/mysql
          sudo systemctl enable --now mariadb
          sudo mariadb -e "ALTER USER 'root'@'localhost' IDENTIFIED BY '$MYSQL_PASS';" 2>/dev/null
        fi
      fi
    else
      success "$s instalado"
    fi
  done
}

start() {
  header "INICIAR SERVICIOS"
  for s in "${SERVICES[@]}"; do
    if check_service "$s"; then
      warning "$s ya está activo"
    else
      log "Iniciando $s..."
      sudo systemctl start "$s"
      if check_service "$s"; then
        success "$s iniciado correctamente"
      else
        error "No se pudo iniciar $s"
        sudo journalctl -u "$s" -n 10 --no-pager
      fi
    fi
  done
}

stop() {
  header "DETENER SERVICIOS"
  for s in "${SERVICES[@]}"; do
    if ! check_service "$s"; then
      warning "$s ya está detenido"
    else
      log "Deteniendo $s..."
      sudo systemctl stop "$s"
      if ! check_service "$s"; then
        success "$s detenido correctamente"
      else
        error "No se pudo detener $s"
      fi
    fi
  done
}

restart() {
  header "REINICIAR SERVICIOS"
  stop
  sleep 2
  start
}

status() {
  header "ESTADO DE SERVICIOS"
  for i in "${!SERVICES[@]}"; do
    s="${SERVICES[$i]}"
    name="${SERVICE_NAMES[$i]}"
    echo -e "${BOLD}$name:${NC}"
    if check_service "$s"; then
      echo -e "  ${GREEN}● ACTIVO${NC}"
      systemctl status "$s" --no-pager --lines=3 | tail -3 | sed 's/^/  /'
    else
      echo -e "  ${RED}○ INACTIVO${NC}"
    fi
    echo ""
  done

  # Info extra de Apache
  if check_service "httpd"; then
    echo -e "${BOLD}Prueba de configuración Apache:${NC}"
    sudo httpd -t 2>&1 | head -3 | sed 's/^/  /'
    echo ""
  fi

  # Info extra de MariaDB
  if check_service "mariadb" && check_mysql; then
    echo -e "${BOLD}MariaDB - Bases de datos:${NC}"
    mariadb -u "$MYSQL_USER" -p"$MYSQL_PASS" -e "SHOW DATABASES;" 2>/dev/null | tail -n +2 | head -5 | sed 's/^/  /'
    echo "  ..."
  fi
}

logs() {
  header "LOGS"
  echo "1. Apache"
  echo "2. MariaDB"
  echo "3. Log del gestor"
  read -p "Selecciona una opción (1-3): " opt
  case $opt in
  1) sudo journalctl -u httpd -f ;;
  2) sudo journalctl -u mariadb -f ;;
  3) tail -f "$LOG_DIR/manager.log" 2>/dev/null || error "No hay logs aún" ;;
  *) error "Opción inválida" ;;
  esac
}

enable() {
  header "HABILITAR ARRANQUE AUTOMÁTICO"
  for s in "${SERVICES[@]}"; do
    sudo systemctl enable "$s"
    success "$s habilitado"
  done
}

disable() {
  header "DESHABILITAR ARRANQUE AUTOMÁTICO"
  for s in "${SERVICES[@]}"; do
    sudo systemctl disable "$s"
    success "$s deshabilitado"
  done
}

apache_test() {
  header "PRUEBA DE CONFIGURACIÓN DE APACHE"
  sudo httpd -t
}

mysql_backup() {
  header "BACKUP RÁPIDO DE MARIADB"
  if ! check_service "mariadb" || ! check_mysql; then
    error "MariaDB no está activo o no se puede conectar"
    return 1
  fi
  local fecha=$(date +%Y%m%d_%H%M%S)
  local archivo="$BACKUP_DIR/backup_$fecha.sql"
  log "Creando backup en $archivo ..."
  if mysqldump -u "$MYSQL_USER" -p"$MYSQL_PASS" --all-databases >"$archivo" 2>>"$LOG_DIR/backup.log"; then
    gzip "$archivo"
    success "Backup creado: $archivo.gz"
    # Limpiar backups antiguos (más de 7 días)
    find "$BACKUP_DIR" -name "backup_*.sql.gz" -mtime +7 -delete
  else
    error "Error al crear backup"
  fi
}

help() {
  header "AYUDA - WEB MANAGER"
  echo "Uso: $0 [comando]"
  echo ""
  echo "Comandos disponibles:"
  echo "  init         - Inicializar directorios y verificar instalación"
  echo "  start        - Iniciar servicios (Apache y MariaDB)"
  echo "  stop         - Detener servicios"
  echo "  restart      - Reiniciar servicios"
  echo "  status       - Mostrar estado detallado"
  echo "  logs         - Ver logs en tiempo real"
  echo "  enable       - Activar arranque automático"
  echo "  disable      - Desactivar arranque automático"
  echo "  apache-test  - Probar configuración de Apache"
  echo "  mysql-backup - Hacer backup rápido de todas las BD"
  echo "  menu         - Mostrar menú interactivo"
  echo "  help         - Mostrar esta ayuda"
  echo ""
  echo "Ejemplos:"
  echo "  $0 start"
  echo "  $0 status"
  echo "  $0 apache-test"
}

# ============================================
# MENÚ INTERACTIVO
# ============================================
interactive_menu() {
  while true; do
    clear
    header "GESTOR DE SERVICIOS WEB"
    echo "1. Inicializar"
    echo "2. Iniciar servicios"
    echo "3. Detener servicios"
    echo "4. Reiniciar servicios"
    echo "5. Estado"
    echo "6. Ver logs"
    echo "7. Habilitar arranque automático"
    echo "8. Deshabilitar arranque automático"
    echo "9. Probar configuración Apache"
    echo "10. Backup rápido de MariaDB"
    echo "11. Ayuda"
    echo "0. Salir"
    echo ""
    read -p "Selecciona una opción (0-11): " choice
    case $choice in
    1) initialize ;;
    2) start ;;
    3) stop ;;
    4) restart ;;
    5) status ;;
    6) logs ;;
    7) enable ;;
    8) disable ;;
    9) apache_test ;;
    10) mysql_backup ;;
    11) help ;;
    0)
      echo ""
      success "¡Hasta pronto!"
      exit 0
      ;;
    *)
      error "Opción inválida"
      sleep 2
      ;;
    esac
    echo ""
    read -p "Presiona Enter para continuar..." -n 1
  done
}

# ============================================
# MAIN
# ============================================
check_root
mkdir -p "$LOG_DIR" "$BACKUP_DIR"

if [ $# -eq 0 ]; then
  interactive_menu
else
  case "$1" in
  init | initialize) initialize ;;
  start) start ;;
  stop) stop ;;
  restart) restart ;;
  status) status ;;
  logs) logs ;;
  enable) enable ;;
  disable) disable ;;
  apache-test) apache_test ;;
  mysql-backup) mysql_backup ;;
  menu) interactive_menu ;;
  help | --help | -h) help ;;
  *)
    error "Comando desconocido: $1"
    echo ""
    help
    exit 1
    ;;
  esac
fi
