#!/bin/bash
# docker-manager.sh - Gestión del entorno Docker para Laravel
# Autor: Arch Linux User
# Uso: docker-manager.sh [comando]

# ============================================
# CONFIGURACIÓN
# ============================================
PROJECT_DIR="$(pwd)"           # Directorio actual (raíz del proyecto)
COMPOSE_FILE="docker-compose.yml"
LOG_DIR="$HOME/.config/docker-manager/logs"
BACKUP_DIR="$HOME/Backups/Docker"

# Lista de servicios del docker-compose.yml
SERVICES=("app" "webserver" "db" "node")
SERVICE_NAMES=("App PHP 8.4" "Nginx" "MySQL 8.0" "Node.js")

# ============================================
# COLORES Y FORMATOS
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ============================================
# FUNCIONES DE UTILIDAD
# ============================================
log() {
  echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

success() {
  echo -e "${GREEN}✓${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

warning() {
  echo -e "${YELLOW}⚠${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

error() {
  echo -e "${RED}✗${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

header() {
  echo -e "${CYAN}${BOLD}============================================${NC}"
  echo -e "${CYAN}${BOLD}    $1${NC}"
  echo -e "${CYAN}${BOLD}============================================${NC}"
}

check_root() {
  if [[ $EUID -eq 0 ]]; then
    error "No ejecutes este script como root/sudo. Usa tu usuario normal."
    exit 1
  fi
}

check_docker_compose() {
  if ! command -v docker compose &> /dev/null; then
    error "'docker compose' no está disponible en el sistema."
    return 1
  fi
}

check_project() {
  if [ ! -f "$COMPOSE_FILE" ]; then
    error "No se encontró $COMPOSE_FILE en el directorio actual."
    warning "Asegúrate de ejecutar el script desde la raíz del proyecto Laravel."
    return 1
  fi
}

# ============================================
# FUNCIONES PRINCIPALES
# ============================================

initialize() {
  header "INICIALIZACIÓN"
  mkdir -p "$LOG_DIR" "$BACKUP_DIR"
  success "Directorio de logs creado: $LOG_DIR"
  success "Directorio de backups creado: $BACKUP_DIR"

  if check_docker_compose && check_project; then
    success "Entorno listo: docker-compose disponible y proyecto encontrado."
  else
    error "Falta docker-compose o archivo del proyecto."
    exit 1
  fi
}

start_containers() {
  header "LEVANTAR CONTENEDORES"
  if ! check_docker_compose || ! check_project; then
    return 1
  fi

  log "Levantando todos los contenedores en segundo plano..."
  docker compose -f "$COMPOSE_FILE" up -d
  if [ $? -eq 0 ]; then
    success "Contenedores levantados correctamente"
    echo ""
    status_containers
  else
    error "Falló al levantar los contenedores"
  fi
}

stop_containers() {
  header "DETENER CONTENEDORES"
  if ! check_docker_compose || ! check_project; then
    return 1
  fi

  log "Deteniendo todos los contenedores..."
  docker compose -f "$COMPOSE_FILE" stop
  if [ $? -eq 0 ]; then
    success "Contenedores detenidos correctamente"
  else
    error "Falló al detener los contenedores"
  fi
}

restart_container() {
  local service="$1"
  if [ -z "$service" ]; then
    error "Debes especificar el nombre del servicio"
    echo "Servicios disponibles: ${SERVICES[*]}"
    return 1
  fi

  header "REINICIAR SERVICIO: $service"
  if ! check_docker_compose || ! check_project; then
    return 1
  fi

  log "Reiniciando $service..."
  docker compose -f "$COMPOSE_FILE" restart "$service"
  if [ $? -eq 0 ]; then
    success "Servicio $service reiniciado"
  else
    error "Falló al reiniciar $service"
  fi
}

status_containers() {
  header "ESTADO DE CONTENEDORES"
  if ! check_docker_compose || ! check_project; then
    return 1
  fi

  docker compose -f "$COMPOSE_FILE" ps
  echo ""

  # Mostrar información adicional para cada servicio activo
  for i in "${!SERVICES[@]}"; do
    service="${SERVICES[$i]}"
    name="${SERVICE_NAMES[$i]}"
    # Ver si el contenedor está corriendo (usando docker compose ps --format json)
    running=$(docker compose -f "$COMPOSE_FILE" ps --format json "$service" | grep -c '"State":"running"')
    if [ "$running" -gt 0 ]; then
      case "$service" in
        app)
          echo -e "${BOLD}$name - Versión PHP:${NC}"
          docker compose exec "$service" php -v | head -1 | sed 's/^/  /'
          ;;
        db)
          echo -e "${BOLD}$name - Versión MySQL:${NC}"
          docker compose exec "$service" mysql --version | sed 's/^/  /'
          ;;
        node)
          echo -e "${BOLD}$name - Versión Node:${NC}"
          docker compose exec "$service" node -v 2>/dev/null | sed 's/^/  /'
          ;;
      esac
    else
      echo -e "${BOLD}$name:${NC} ${YELLOW}Contenedor detenido${NC}"
    fi
    echo ""
  done
}

view_logs() {
  header "LOGS"
  echo "1. Todos los contenedores (seguimiento)"
  echo "2. Solo App (PHP)"
  echo "3. Solo Webserver (Nginx)"
  echo "4. Solo Base de Datos (MySQL)"
  echo "5. Solo Node"
  echo "6. Log del gestor (docker-manager.log)"
  read -p "Selecciona una opción (1-6): " opt

  case $opt in
    1)
      docker compose -f "$COMPOSE_FILE" logs -f --tail=50
      ;;
    2)
      docker compose -f "$COMPOSE_FILE" logs -f --tail=50 app
      ;;
    3)
      docker compose -f "$COMPOSE_FILE" logs -f --tail=50 webserver
      ;;
    4)
      docker compose -f "$COMPOSE_FILE" logs -f --tail=50 db
      ;;
    5)
      docker compose -f "$COMPOSE_FILE" logs -f --tail=50 node
      ;;
    6)
      tail -f "$LOG_DIR/manager.log" 2>/dev/null || error "No hay logs aún"
      ;;
    *)
      error "Opción inválida"
      ;;
  esac
}

down_containers() {
  header "LIMPIAR ENTORNO"
  echo -e "${RED}⚠️  Este comando detendrá y eliminará contenedores, redes y volúmenes huérfanos.${NC}"
  read -p "¿Estás seguro? (s/N): " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Ss]$ ]]; then
    warning "Operación cancelada"
    return
  fi

  if ! check_docker_compose || ! check_project; then
    return 1
  fi

  log "Eliminando entorno (down -v)..."
  docker compose -f "$COMPOSE_FILE" down -v
  if [ $? -eq 0 ]; then
    success "Entorno limpiado correctamente"
  else
    error "Falló la limpieza"
  fi
}

start_docker_service() {
  header "INICIAR SERVICIO DOCKER DEL SISTEMA"
  log "Iniciando docker.service..."
  sudo systemctl start docker
  sudo systemctl enable docker &>/dev/null
  if systemctl is-active --quiet docker; then
    success "Servicio Docker activo"
  else
    error "No se pudo iniciar Docker"
  fi
}

stop_docker_service() {
  header "DETENER SERVICIO DOCKER DEL SISTEMA"
  log "Deteniendo docker.service..."
  sudo systemctl stop docker
  if ! systemctl is-active --quiet docker; then
    success "Servicio Docker detenido"
  else
    error "No se pudo detener Docker"
  fi
}

restart_docker_service() {
  header "REINICIAR SERVICIO DOCKER DEL SISTEMA"
  log "Reiniciando docker.service..."
  sudo systemctl restart docker
  if systemctl is-active --quiet docker; then
    success "Servicio Docker reiniciado"
  else
    error "No se pudo reiniciar Docker"
  fi
}

docker_backup() {
  header "BACKUP DE VOLUMENES DOCKER"
  local fecha=$(date +%Y%m%d_%H%M%S)
  local backup_file="$BACKUP_DIR/docker_volumes_$fecha.tar.gz"

  if ! docker volume ls -q | grep -q .; then
    warning "No hay volúmenes Docker para respaldar"
    return
  fi

  log "Creando backup de todos los volúmenes en $backup_file ..."
  docker run --rm -v /var/run/docker.sock:/var/run/docker.sock -v "$BACKUP_DIR:/backup" alpine tar czf "/backup/docker_volumes_$fecha.tar.gz" -C /var/lib/docker/volumes . 2>>"$LOG_DIR/backup.log"
  if [ $? -eq 0 ]; then
    success "Backup creado: $backup_file"
    # Limpiar backups antiguos (más de 30 días)
    find "$BACKUP_DIR" -name "docker_volumes_*.tar.gz" -mtime +30 -delete
  else
    error "Error al crear backup"
  fi
}

help() {
  header "AYUDA - DOCKER MANAGER"
  echo "Uso: $0 [comando]"
  echo ""
  echo "Comandos disponibles:"
  echo "  init            - Inicializar directorios y verificar entorno"
  echo "  start           - Levantar todos los contenedores (app, webserver, db, node)"
  echo "  stop            - Detener todos los contenedores"
  echo "  restart [serv]  - Reiniciar un servicio específico (app, webserver, db, node)"
  echo "  status          - Mostrar estado detallado de contenedores"
  echo "  logs            - Ver logs en tiempo real"
  echo "  down            - Detener y eliminar contenedores + volúmenes (limpieza total)"
  echo "  docker-start    - Iniciar el servicio Docker del sistema (sudo)"
  echo "  docker-stop     - Detener el servicio Docker del sistema (sudo)"
  echo "  docker-restart  - Reiniciar el servicio Docker del sistema (sudo)"
  echo "  backup          - Hacer backup de los volúmenes Docker"
  echo "  menu            - Mostrar menú interactivo"
  echo "  help            - Mostrar esta ayuda"
  echo ""
  echo "Ejemplos:"
  echo "  $0 start"
  echo "  $0 restart app"
  echo "  $0 docker-start"
}

# ============================================
# MENÚ INTERACTIVO
# ============================================
interactive_menu() {
  while true; do
    clear
    header "GESTOR DE ENTORNO DOCKER - LARAVEL"
    echo "1. Inicializar entorno"
    echo "2. Levantar contenedores"
    echo "3. Detener contenedores"
    echo "4. Reiniciar servicio específico"
    echo "5. Estado de contenedores"
    echo "6. Ver logs"
    echo "7. Limpiar entorno (down -v)"
    echo "8. Control del servicio Docker del sistema"
    echo "9. Backup de volúmenes Docker"
    echo "10. Ayuda"
    echo "0. Salir"
    echo ""
    read -p "Selecciona una opción (0-10): " choice
    case $choice in
    1) initialize ;;
    2) start_containers ;;
    3) stop_containers ;;
    4)
      echo "Servicios disponibles: ${SERVICES[*]}"
      read -p "Nombre del servicio: " serv
      restart_container "$serv"
      ;;
    5) status_containers ;;
    6) view_logs ;;
    7) down_containers ;;
    8)
      echo "1. Iniciar servicio Docker"
      echo "2. Detener servicio Docker"
      echo "3. Reiniciar servicio Docker"
      read -p "Opción: " opt
      case $opt in
        1) start_docker_service ;;
        2) stop_docker_service ;;
        3) restart_docker_service ;;
        *) error "Opción inválida" ;;
      esac
      ;;
    9) docker_backup ;;
    10) help ;;
    0)
      echo ""
      success "¡Hasta pronto!"
      exit 0
      ;;
    *)
      error "Opción inválida"
      sleep 2
      ;;
    esac
    echo ""
    read -p "Presiona Enter para continuar..." -n 1
  done
}

# ============================================
# MAIN
# ============================================
check_root
mkdir -p "$LOG_DIR" "$BACKUP_DIR"

if [ $# -eq 0 ]; then
  interactive_menu
else
  case "$1" in
  init | initialize) initialize ;;
  start) start_containers ;;
  stop) stop_containers ;;
  restart) restart_container "$2" ;;
  status) status_containers ;;
  logs) view_logs ;;
  down) down_containers ;;
  docker-start) start_docker_service ;;
  docker-stop) stop_docker_service ;;
  docker-restart) restart_docker_service ;;
  backup) docker_backup ;;
  menu) interactive_menu ;;
  help | --help | -h) help ;;
  *)
    error "Comando desconocido: $1"
    echo ""
    help
    exit 1
    ;;
  esac
fi
