#!/bin/bash
# print-manager.sh - Gestión de servicios de impresión (CUPS y Avahi)
# Autor: Arch Linux User
# Uso: print-manager.sh [comando]

# ============================================
# CONFIGURACIÓN
# ============================================
CONFIG_DIR="$HOME/.config/print-manager"
LOG_DIR="$CONFIG_DIR/logs"
SERVICES=("cups" "avahi-daemon")
SERVICE_NAMES=("CUPS" "Avahi")

# ============================================
# COLORES Y FORMATOS
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'
BOLD='\033[1m'

# ============================================
# FUNCIONES DE UTILIDAD
# ============================================
log() {
    echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

success() {
    echo -e "${GREEN}✓${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

warning() {
    echo -e "${YELLOW}⚠${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

error() {
    echo -e "${RED}✗${NC} $1" | tee -a "$LOG_DIR/manager.log"
}

header() {
    echo -e "${CYAN}${BOLD}============================================${NC}"
    echo -e "${CYAN}${BOLD}    $1${NC}"
    echo -e "${CYAN}${BOLD}============================================${NC}"
}

check_root() {
    if [[ $EUID -eq 0 ]]; then
        error "No ejecutes este script como root/sudo. Usa tu usuario normal."
        exit 1
    fi
}

check_service() {
    systemctl is-active --quiet "$1" 2>/dev/null
}

# ============================================
# FUNCIONES PRINCIPALES
# ============================================

initialize() {
    header "INICIALIZACIÓN"
    mkdir -p "$CONFIG_DIR" "$LOG_DIR"
    success "Directorios creados en $CONFIG_DIR"
    for s in "${SERVICES[@]}"; do
        if ! systemctl list-unit-files | grep -q "$s.service"; then
            warning "$s no está instalado"
            read -p "¿Instalar $s ahora? (s/n): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Ss]$ ]]; then
                sudo pacman -S --needed --noconfirm "$s"
            fi
        else
            success "$s instalado"
        fi
    done
}

start() {
    header "INICIAR SERVICIOS"
    for s in "${SERVICES[@]}"; do
        if check_service "$s"; then
            warning "$s ya está activo"
        else
            log "Iniciando $s..."
            sudo systemctl start "$s"
            if check_service "$s"; then
                success "$s iniciado correctamente"
            else
                error "No se pudo iniciar $s"
                sudo journalctl -u "$s" -n 10 --no-pager
            fi
        fi
    done
}

stop() {
    header "DETENER SERVICIOS"
    for s in "${SERVICES[@]}"; do
        if ! check_service "$s"; then
            warning "$s ya está detenido"
        else
            log "Deteniendo $s..."
            sudo systemctl stop "$s"
            if ! check_service "$s"; then
                success "$s detenido correctamente"
            else
                error "No se pudo detener $s"
            fi
        fi
    done
}

restart() {
    header "REINICIAR SERVICIOS"
    stop
    sleep 2
    start
}

status() {
    header "ESTADO DE SERVICIOS"
    for i in "${!SERVICES[@]}"; do
        s="${SERVICES[$i]}"
        name="${SERVICE_NAMES[$i]}"
        echo -e "${BOLD}$name:${NC}"
        if check_service "$s"; then
            echo -e "  ${GREEN}● ACTIVO${NC}"
            systemctl status "$s" --no-pager --lines=3 | tail -3 | sed 's/^/  /'
        else
            echo -e "  ${RED}○ INACTIVO${NC}"
        fi
        echo ""
    done

    # Información adicional de CUPS
    if check_service "cups"; then
        echo -e "${BOLD}Colas de impresión:${NC}"
        lpstat -p 2>/dev/null | head -10 | sed 's/^/  /' || echo "  No hay impresoras configuradas"
        echo ""
    fi
}

logs() {
    header "LOGS"
    echo "1. CUPS"
    echo "2. Avahi"
    echo "3. Log del gestor"
    read -p "Selecciona una opción (1-3): " opt
    case $opt in
        1) sudo journalctl -u cups -f ;;
        2) sudo journalctl -u avahi-daemon -f ;;
        3) tail -f "$LOG_DIR/manager.log" 2>/dev/null || error "No hay logs aún" ;;
        *) error "Opción inválida" ;;
    esac
}

enable() {
    header "HABILITAR ARRANQUE AUTOMÁTICO"
    for s in "${SERVICES[@]}"; do
        sudo systemctl enable "$s"
        success "$s habilitado"
    done
}

disable() {
    header "DESHABILITAR ARRANQUE AUTOMÁTICO"
    for s in "${SERVICES[@]}"; do
        sudo systemctl disable "$s"
        success "$s deshabilitado"
    done
}

help() {
    header "AYUDA - PRINT MANAGER"
    echo "Uso: $0 [comando]"
    echo ""
    echo "Comandos disponibles:"
    echo "  init        - Inicializar directorios y verificar instalación"
    echo "  start       - Iniciar servicios"
    echo "  stop        - Detener servicios"
    echo "  restart     - Reiniciar servicios"
    echo "  status      - Mostrar estado detallado"
    echo "  logs        - Ver logs en tiempo real"
    echo "  enable      - Activar arranque automático"
    echo "  disable     - Desactivar arranque automático"
    echo "  menu        - Mostrar menú interactivo"
    echo "  help        - Mostrar esta ayuda"
    echo ""
    echo "Ejemplos:"
    echo "  $0 start"
    echo "  $0 status"
    echo "  $0 logs"
}

# ============================================
# MENÚ INTERACTIVO
# ============================================
interactive_menu() {
    while true; do
        clear
        header "GESTOR DE IMPRESIÓN"
        echo "1. Inicializar"
        echo "2. Iniciar servicios"
        echo "3. Detener servicios"
        echo "4. Reiniciar servicios"
        echo "5. Estado"
        echo "6. Ver logs"
        echo "7. Habilitar arranque automático"
        echo "8. Deshabilitar arranque automático"
        echo "9. Ayuda"
        echo "0. Salir"
        echo ""
        read -p "Selecciona una opción (0-9): " choice
        case $choice in
            1) initialize ;;
            2) start ;;
            3) stop ;;
            4) restart ;;
            5) status ;;
            6) logs ;;
            7) enable ;;
            8) disable ;;
            9) help ;;
            0) echo ""; success "¡Hasta pronto!"; exit 0 ;;
            *) error "Opción inválida"; sleep 2 ;;
        esac
        echo ""
        read -p "Presiona Enter para continuar..." -n 1
    done
}

# ============================================
# MAIN
# ============================================
check_root
mkdir -p "$LOG_DIR"

if [ $# -eq 0 ]; then
    interactive_menu
else
    case "$1" in
        init|initialize) initialize ;;
        start) start ;;
        stop) stop ;;
        restart) restart ;;
        status) status ;;
        logs) logs ;;
        enable) enable ;;
        disable) disable ;;
        menu) interactive_menu ;;
        help|--help|-h) help ;;
        *) error "Comando desconocido: $1"; echo ""; help; exit 1 ;;
    esac
fi
