#!/bin/bash

# --- CONFIGURACIĂ“N ---
BLACK_BG="$HOME/.config/i3/fondos/black.png"
DEFAULT_FEHBG="feh --randomize --bg-fill"

# --- FUNCIĂ“N DE LIMPIEZA ---
cleanup() {
  echo -e "\nSaliendo... Restaurando configuraciĂłn original."

  # Detener procesos
  killall mpv 2>/dev/null
  killall xwinwrap 2>/dev/null

  # Solo restaurar fondo si picom estĂˇ activo
  if pgrep -x "picom" >/dev/null; then
    echo "Picom detectado, restaurando fondo original..."
    $DEFAULT_FEHBG ~/.config/i3/fondos/*
  fi

  exit 0
}

# --- FUNCIĂ“N PARA OBTENER MONITORES CON RESOLUCIĂ“N ---
get_monitors() {
  xrandr --current | grep " connected" | while read -r line; do
    # Extraer nombre del monitor
    monitor=$(echo "$line" | awk '{print $1}')

    # Buscar resoluciĂłn activa (la que tiene el *)
    if [[ "$line" =~ \+ ]] || [[ "$line" =~ [0-9]+x[0-9]+\+[0-9]+\+[0-9]+ ]]; then
      # Si ya tiene la geometrĂ­a en la lĂ­nea principal
      geometry=$(echo "$line" | grep -oP '\d+x\d+\+\d+\+\d+' | head -1)
    else
      # Buscar en las siguientes lĂ­neas la resoluciĂłn activa
      geometry=$(xrandr --current | grep -A 5 "^$monitor" | grep -oP '\d+x\d+\+\d+\+\d+' | head -1)
    fi

    # Si encontramos geometrĂ­a, procesamos
    if [ -n "$geometry" ]; then
      # Obtener solo la resoluciĂłn (sin posiciĂłn)
      resolution=$(echo "$geometry" | cut -d'+' -f1)

      # Obtener posiciĂłn (offset)
      position="+$(echo "$geometry" | cut -d'+' -f2)+$(echo "$geometry" | cut -d'+' -f3)"

      # Crear geometrĂ­a completa con posiciĂłn
      full_geometry="${resolution}${position}"

      # Guardar informaciĂłn del monitor
      echo "$monitor:$full_geometry:$resolution"
    fi
  done
}

# --- FUNCIĂ“N PARA INICIAR VIDEO EN MONITOR ESPECĂŤFICO ---
start_video_on_monitor() {
  local monitor="$1"
  local geometry="$2"
  local resolution="$3"
  local video="$4"

  echo "Iniciando video en monitor: $monitor"
  echo "  GeometrĂ­a: $geometry"
  echo "  ResoluciĂłn: $resolution"

  # Extraer ancho y alto para las opciones de mpv
  local width=$(echo "$resolution" | cut -d'x' -f1)
  local height=$(echo "$resolution" | cut -d'x' -f2)

  # Usar xwinwrap con geometrĂ­a especĂ­fica del monitor
  # y opciones optimizadas para la resoluciĂłn
  xwinwrap -g "$geometry" -ov -s -st -sp -nf -- \
    mpv -wid WID --no-audio --loop=inf \
    --hwdec=auto --no-border \
    --no-osc --no-osd-bar --quiet \
    --ontop --no-input-default-bindings \
    --keepaspect=yes \
    --keepaspect-window=yes \
    --video-unscaled=no \
    --autofit="$resolution" \
    --geometry="$resolution" \
    --video-zoom=0 \
    --video-pan-x=0 --video-pan-y=0 \
    --video-align-x=0 --video-align-y=0 \
    --vo=xv \
    "$video" &

  # PequeĂ±a pausa entre instancias
  sleep 0.5
}

# --- FUNCIĂ“N PARA OBTENER LA RESOLUCIĂ“N TOTAL DEL ESCRITORIO ---
get_desktop_resolution() {
  local total_width=0
  local max_height=0

  while IFS= read -r monitor_info; do
    if [ -n "$monitor_info" ]; then
      resolution=$(echo "$monitor_info" | cut -d':' -f3)
      width=$(echo "$resolution" | cut -d'x' -f1)
      height=$(echo "$resolution" | cut -d'x' -f2)

      # Sumar anchos para obtener ancho total
      total_width=$((total_width + width))

      # Actualizar altura mĂˇxima
      if [ "$height" -gt "$max_height" ]; then
        max_height=$height
      fi
    fi
  done <<<"$1"

  echo "${total_width}x${max_height}"
}

# --- ATRApar SEĂ‘ALES ---
trap cleanup SIGINT SIGTERM SIGTSTP

# --- VERIFICACIĂ“N DE ARGUMENTOS ---
VIDEO_PATH="$1"
if [ -z "$VIDEO_PATH" ] || [ ! -f "$VIDEO_PATH" ]; then
  echo "Error: Debes proporcionar una ruta vĂˇlida a un archivo de video."
  echo "Uso: $0 /ruta/al/video.mp4"
  exit 1
fi

# --- LIMPIEZA DE PROCESOS ANTERIORES ---
killall xwinwrap 2>/dev/null
killall mpv 2>/dev/null

# --- INICIALIZACIĂ“N CONDICIONAL DEL FONDO ---
if pgrep -x "picom" >/dev/null; then
  echo "Picom detectado, configurando fondo temporal..."
  if [ -f "$BLACK_BG" ]; then
    feh --bg-scale "$BLACK_BG"
  else
    # Crear fondo negro temporal si no existe
    convert -size 1x1 xc:black /tmp/black_bg.png 2>/dev/null || {
      # Si convert no estĂˇ disponible, usar un comando alternativo
      echo "Creando fondo negro con ffmpeg..."
      ffmpeg -f lavfi -i color=c=black:s=1x1 -frames:v 1 /tmp/black_bg.png 2>/dev/null || {
        # Si todo falla, usar un fondo negro simple con feh
        feh --bg-scale /dev/null
      }
    }
    feh --bg-scale /tmp/black_bg.png 2>/dev/null
  fi
fi

# --- OBTENER MONITORES ---
MONITORS=$(get_monitors)
MONITOR_COUNT=$(echo "$MONITORS" | wc -l)

echo "Monitores detectados: $MONITOR_COUNT"
echo "InformaciĂłn de monitores:"
echo "$MONITORS" | while IFS= read -r line; do
  if [ -n "$line" ]; then
    monitor=$(echo "$line" | cut -d':' -f1)
    geometry=$(echo "$line" | cut -d':' -f2)
    resolution=$(echo "$line" | cut -d':' -f3)
    echo "  - $monitor: $resolution (pos: $(echo $geometry | cut -d'+' -f2-3))"
  fi
done

# --- OBTENER RESOLUCIĂ“N TOTAL DEL ESCRITORIO ---
DESKTOP_RES=$(get_desktop_resolution "$MONITORS")
echo "ResoluciĂłn total del escritorio: $DESKTOP_RES"

# --- INICIAR EL FONDO DE VIDEO EN CADA MONITOR ---
echo -e "\nIniciando video: $VIDEO_PATH"
echo "Creando instancia por monitor con resoluciĂłn adaptada..."

while IFS= read -r monitor_info; do
  if [ -n "$monitor_info" ]; then
    monitor=$(echo "$monitor_info" | cut -d':' -f1)
    geometry=$(echo "$monitor_info" | cut -d':' -f2)
    resolution=$(echo "$monitor_info" | cut -d':' -f3)
    start_video_on_monitor "$monitor" "$geometry" "$resolution" "$VIDEO_PATH"
  fi
done <<<"$MONITORS"

# Esperar a que se creen las ventanas
echo "Esperando que las ventanas se inicien..."
sleep 3

# Verificar que los procesos estĂ©n corriendo
if pgrep -f "mpv.*$VIDEO_PATH" >/dev/null; then
  echo "âś“ Videos iniciados correctamente"
  echo "âś“ Los videos se reproducirĂˇn de forma continua"
else
  echo "âś— Error: Los videos no se iniciaron correctamente"
  exit 1
fi

# Reiniciar picom si estĂˇ activo (para excluir las ventanas)
if pgrep -x "picom" >/dev/null; then
  echo "Reiniciando picom para aplicar exclusiones..."
  pkill -USR1 picom || true
fi

# --- MANTENER EL SCRIPT EN EJECUCIĂ“N ---
echo -e "\nđźŽ¬ Fondos de video activos en ambos monitores"
echo "đź“ş Video adaptado a la resoluciĂłn de cada monitor"
echo "âš ď¸Ź  Presiona Ctrl+C para detener los videos y restaurar el fondo normal"
echo "đź”„ Los videos se reproducirĂˇn en bucle infinito"

# Mantener el script corriendo hasta que el usuario presione Ctrl+C
while true; do
  # Verificar cada 5 segundos que los procesos sigan vivos
  if ! pgrep -f "mpv.*$VIDEO_PATH" >/dev/null; then
    echo "âš ď¸Ź  Se detectĂł que los procesos de video terminaron. Reiniciando..."
    # Reiniciar los videos si murieron
    while IFS= read -r monitor_info; do
      if [ -n "$monitor_info" ]; then
        monitor=$(echo "$monitor_info" | cut -d':' -f1)
        geometry=$(echo "$monitor_info" | cut -d':' -f2)
        resolution=$(echo "$monitor_info" | cut -d':' -f3)
        start_video_on_monitor "$monitor" "$geometry" "$resolution" "$VIDEO_PATH"
      fi
    done <<<"$MONITORS"
    sleep 3
  fi
  sleep 5
done
