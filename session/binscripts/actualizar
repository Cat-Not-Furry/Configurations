#!/usr/bin/env bash

set -euo pipefail

# Función para mostrar mensaje de error y salir
fallo() {
  echo -e "\n\033[1;31mAlgo falló... ¿Será que Windows hizo de las suyas? >:v\033[0m"
  exit 1
}

# Capturar Ctrl+C para mostrar el mismo mensaje de fallo
trap fallo INT

# Introducción
echo -e "\n\033[1;36m¡Por el poder de Torvalds!"
sleep 1
echo "¡Arch... Yo te actualizo!"
sleep 1

echo -e "\n\033[1;36mActualizando sistema...\033[0m"

# Primer prompt: pacman
read -p $'\n\033[0;33m¿Actualizar pacman? \':| (S/n) \033[0m' act_pac

if [[ "$act_pac" =~ ^[Ss]$ ]]; then
  # Ejecutar pacman y si falla (incluyendo Ctrl+C) llamar a fallo
  if ! sudo pacman -Syu; then
    fallo
  fi
  echo -e "\n\033[1;32m¡Actualización completa con éxito! :v\033[0m"
else
  fallo
fi

# Segundo prompt: yay
read -p $'\n\033[0;33m¿Actualizar paquetes AUR? \':| (S/n) \033[0m' act_yay

if [[ "$act_yay" =~ ^[Ss]$ ]]; then
  if ! yay -Syu; then
    fallo
  fi
  echo -e "\n\033[1;32m¡Actualización completa con éxito! :v\033[0m"
else
  fallo
fi
