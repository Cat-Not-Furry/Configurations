{
    "layer": "top",
    "position": "top",
    "height": 26,
    "spacing": 4,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["custom/cmus"],
    "modules-right": ["cpu", "custom/temp", "memory", "disk", "pulseaudio", "backlight", "battery", "custom/keyboard-toggle", "custom/hostname", "custom/date", "tray"],

    // --- M├ôDULOS DE LA IZQUIERDA ---
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "´äæ",
            "active": "¾░Çâ",
            "urgent": "´äæ"
        },
        "persistent_workspaces": {
            "*": 5 // Muestra al menos 5 workspaces
        }
    },
    "hyprland/window": {
        "format": "´üí {} ´üá",
        "max-length": 60
    },

    // --- M├ôDULO CENTRAL ---
    "custom/cmus": {
        "format": "´Çü {}",
        "interval": 2,
        "exec": "~/.config/waybar/scripts/cmus_status.sh",
        "on-click": "cmus-remote --pause",
        "on-scroll-up": "cmus-remote --next",
        "on-scroll-down": "cmus-remote --prev"
    },

    // --- M├ôDULOS DE LA DERECHA ---
    "cpu": {
        "format": "{icon}{usage}%",
        "format-icons": ["¾░¥å ", "¾░¥à ", "¾░ôà "],
        "on-click": "alacritty -e htop"
    },
    "custom/temp": {
        "exec": "~/.config/waybar/scripts/temp_status.sh",
        "format": "{}",
        "interval": 3
    },
    "memory": {
        "format": "¯┐à {}%",
        "tooltip-format": "{used:0.2f}GB / {total:0.2f}GB",
        "interval": 3
    },
    "disk": {
        "interval": 120,
        "format": "´éá {percentage_used}%",
        "path": "/"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "´æĞ Muted",
        "format-icons": {
            "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
        },
        "on-click": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["¾░âŞ", "¾░âş", "¾░âá"]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´ùğ {capacity}%",
        "format-plugged": "´çĞ {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "custom/keyboard-toggle": {
        "exec": "~/.config/waybar/scripts/keyboard_status.sh",
        "format": "{}",
        "interval": 2,
        "on-click": "~/.local/bin/toggle-keyboard.sh"
    },
    "custom/hostname": {
        "exec": "cat /etc/hostname",
        "format": "´äë {}",
        "interval": "once"
    },
    "custom/date": {
        "exec": "~/.config/waybar/scripts/waybar_date_icon.sh", // Renombramos el script
        "format": "´ü│ {}",
        "interval": 1,
        "on-click": "alacritty -e bash -c 'cal -y; read'"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 5
    }
}
